# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Jupyter ---
.ipynb_checkpoints/

# --- Environment variables / secrets ---
.env
.env.local
*.key

# --- Data (large files; keep raw/processed data out of git) ---
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# --- Vector store (large index files; keep dir but not contents) ---
vector_store/*
!vector_store/.gitkeep

# --- OS / Editor ---
.DS_Store
Thumbs.db
.idea/


# --- Build artifacts ---
build/
dist/
*.egg-info/